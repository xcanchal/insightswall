		"lucide-react": "^1.7.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"shadcn": "^4.2.0",
		"sonner": "^2.0.7",
