{
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev": "concurrently -n @app/api,@app/web -c blue,green \"npm run dev --workspace=@app/api\" \"npm run dev --workspace=@app/web\"",
		"dev:api": "npm run dev --workspace=@app/api",
		"dev:web": "npm run dev --workspace=@app/web",
		"format": "npm run format --workspaces",
		"format:check": "npm run format:check --workspaces",
		"build": "npm run build --workspaces",
		"lint": "eslint .",
		"test": "npm run test --workspaces",
		"test:watch": "npm run test:watch --workspaces",
		"typecheck": "npm run typecheck --workspaces",
		"prepare": "husky install"
	},
	"overrides": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0"
	},
	"dependencies": {
		"@types/node": "^20.11.17",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"husky": "^8.0.0",
		"prettier": "^3.6.2",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"typescript": "^5.9.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"eslint": "^9.39.4",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.5.0",
		"typescript-eslint": "^8.58.2"
	}
}
